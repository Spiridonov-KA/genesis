% \numchapter=1, если глава начата командой \chapter
% \numchapter=0, если глава начата командой \chapter*
\newcounter{numchapter}
\newcommand{\numchapter}{\arabic{numchapter}}

\setcounter{secnumdepth}{2}

\renewcommand{\@makechapterhead}[1]{
  {
   \hangindent=2cm
   \raggedright\parindent=15pt
   \Large\sffamily             % Шрифт заголовка
   \thechapter.                % Не переводим строчку после номера главы
%   \hspace{2mm}                % Пробел между номером и названием главы
   #1\par                      % Название главы
   \setcounter{numchapter}{1}  % это глава, начатая с \chapter
   \nopagebreak                % Не отрывать заголовок главы от текста
   \vspace{5mm}               % Пробел между заголовком и текстом
  }
}

\renewcommand{\@makeschapterhead}[1]{
  {
   \hangindent=2cm
   \raggedright\parindent=15pt
   \Large\sffamily             % Шрифт заголовка
%  \thechapter.                 % Не переводим строчку после номера главы
%   \hspace{2mm}                % Пробел между номером и названием главы
   #1\par                      % Название главы
   \setcounter{numchapter}{0}  % это глава, начатая с \chapter*
   \nopagebreak                % Не отрывать заголовок главы от текста
   \vspace{5mm}                % Пробел между заголовком и текстом
  }
}

